# TeamRun Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Service LLM Configuration
# ===================
# LLM provider: openai, anthropic, minimax, etc.
TRUN_LLM_PROVIDER=minimax

# Model name
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-opus, claude-3-sonnet, claude-3-haiku
# Minimax: abab6.5s-chat, abab6-chat, abab5.5-chat
TRUN_LLM_MODEL=minimax/MiniMax-M2.5

# ===================
# API Keys
# ===================
# OpenAI API Key
OPENAI_API_KEY=

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=

# Minimax API Key
MINIMAX_API_KEY=

# Tavily API Key (for web search)
TAVILY_API_KEY=
